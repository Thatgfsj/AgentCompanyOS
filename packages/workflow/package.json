{
  "name": "@flowntier/workflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client-side workflow state types, TanStack Query hooks, and event-bus subscription",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./queries": "./src/queries.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@flowntier/shared": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.5"
  }
}
