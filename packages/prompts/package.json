{
  "name": "@flowntier/prompts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prompt template renderer (Handlebars-like, deterministic, no eval).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./renderer": "./src/renderer.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.5"
  }
}
